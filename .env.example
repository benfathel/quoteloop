# Database (PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@localhost:5432/quoteloop?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"

# Twilio (SMS follow-ups)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"       # Found at https://console.twilio.com
TWILIO_AUTH_TOKEN="your-twilio-auth-token"           # Found at https://console.twilio.com
TWILIO_PHONE_NUMBER="+15551234567"                   # Your Twilio phone number in E.164 format

# Stripe (Payments — use test mode keys starting with sk_test_ and pk_test_)
STRIPE_SECRET_KEY="sk_test_..."                      # Found at https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_..."                 # Found at https://dashboard.stripe.com/test/apikeys
STRIPE_WEBHOOK_SECRET="whsec_..."                    # From Stripe CLI or dashboard webhook settings
STRIPE_PRICE_ID="price_..."                          # The Price ID for the $36/month Plus plan

# Cron job security (used to protect /api/cron/follow-ups and /api/cron/reset-quotes)
CRON_SECRET="generate-a-random-secret-for-cron-auth"
